---

<footer class="border-t border-gardn-line mt-24 bg-gardn-paper">
  <div class="mx-auto max-w-6xl px-6 py-14">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8">
      <div>
        <Image
          src={gardnLockupHorizontal}
          alt="Gardn"
          widths={[140, 280]}
          sizes="140px"
          class="h-6 w-auto"
          loading="lazy"
        />
        <p class="text-body-sm text-gardn-muted mt-4 max-w-xs">
          A garden app that grows with you.
        </p>
      </div>

      <nav class="flex flex-col gap-3 md:items-center md:justify-self-center" aria-label="Footer">
        <a href="/privacy" class="text-label text-gardn-muted hover:text-gardn-forest-deep transition-colors">Privacy</a>
        <a href="/terms" class="text-label text-gardn-muted hover:text-gardn-forest-deep transition-colors">Terms</a>
        <a href="/support" class="text-label text-gardn-muted hover:text-gardn-forest-deep transition-colors">Support</a>
      </nav>

      <div class="md:justify-self-end">
        <p class="text-eyebrow text-gardn-muted-sub mb-3">Follow</p>
        <ul class="flex gap-4">
          {
            socials.map((s) => (
              <li>
                <a
                  href={s.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Gardn on ${s.label}`}
                  class="inline-flex items-center justify-center w-9 h-9 rounded-full text-gardn-muted hover:text-gardn-forest-deep hover:bg-gardn-cream transition-colors"
                >
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d={s.path}></path>
                  </svg>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-6 border-t border-gardn-line">
      <p class="text-body-sm text-gardn-muted-sub">
        © {year} Gardn Labs Ltd. Made in the UK.
      </p>
    </div>
  </div>
</footer>
