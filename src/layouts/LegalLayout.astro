---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title?: string;
  description?: string;
  frontmatter?: { title?: string; description?: string };
}

const fm = Astro.props.frontmatter ?? {};
const title = Astro.props.title ?? fm.title;
const description = Astro.props.description ?? fm.description;
---

<BaseLayout title={title} description={description}>
  <article class="prose-legal mx-auto max-w-3xl px-6 pt-16 pb-24 md:pt-20 md:pb-32">
    <slot />
  </article>
</BaseLayout>
