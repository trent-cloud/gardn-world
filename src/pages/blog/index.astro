---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { photoMeadow } from '../../constants/brandAssets';
---

<BaseLayout
  title="Notes — Gardn"
  description="Field notes from Gardn's founders on UK growing, what we're learning, and how the community uses the app. Land here once Gardn launches."
>
  <article class="mx-auto max-w-2xl px-6 pt-16 pb-24 md:pt-24 md:pb-32">
    <Image
      src={photoMeadow}
      alt="A meadow in soft light."
      class="w-full h-72 md:h-96 object-cover rounded-lg"
      widths={[480, 800, 1200]}
      sizes="(min-width: 768px) 672px, 100vw"
    />
    <p class="text-eyebrow text-gardn-fern mt-12">Notes</p>
    <h1 class="text-h1 text-gardn-forest-deep mt-3" style="text-wrap: balance;">
      Notes from the garden.
    </h1>
    <p class="text-body text-gardn-muted mt-6">
      Notes from the garden land here once the app does. Field notes on UK growing, what we're learning building Gardn, and how the community uses it.
    </p>
    <p class="text-body text-gardn-muted mt-4">
      — Trent and Richard, founders.
    </p>
  </article>
</BaseLayout>
