---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  photoBacklit,
  photoCourtyard,
  photoDahlia,
  photoBorder,
  photoHands,
} from '../constants/brandAssets';

const proofPoints = [
  {
    eyebrow: 'Pays attention so you don’t have to.',
    title: 'Notices before you do.',
    body: "Frost coming Wednesday — Gardn's already flagged the hardy-borderline plants in your space. Twelve millimetres of rain yesterday — skip today's watering, you don't need it. The veg window for direct-sown carrots closes in nine days. The nudges arrive in time to do something about them, not after.",
    photo: photoDahlia,
    photoAlt: 'A dahlia in close detail — the kind of moment Gardn helps you notice.',
  },
  {
    eyebrow: 'Tuned to where you grow.',
    title: 'Knows your postcode, not just your latitude.',
    body: "Tomato sowing in Cornwall happens two weeks before Yorkshire. Frost dates shift across regions. The plants that thrive in chalk hate clay. Gardn's calibration starts at the postcode — veg windows, frost thresholds, regional plant data — so the advice you get fits the patch you're actually gardening, not a generic average.",
    photo: photoBorder,
    photoAlt: 'A planted border in mid-season.',
  },
  {
    eyebrow: 'The gardeners on your road.',
    title: 'Local, when there are enough of you.',
    body: "Your community in Gardn is the people gardening near you — same soil, same microclimate, same season-by-season weather as you. When seven gardeners on your road have signed up, the local feed unlocks: photos, questions, cuttings, seed swaps. Until then, it's quiet — and worth telling a neighbour.",
    photo: photoHands,
    photoAlt: 'Hands in soil — the local-community register.',
  },
];
---

<BaseLayout
  title="Gardn — a garden app that grows with you"
  description="Notices what you'd miss. Remembers what you'd forget. The garden app that grows with you — keeping every border, plant and bloom in mind."
>
  <!-- Block 1 — Hero -->
  <section class="relative isolate overflow-hidden bg-gardn-forest-deep">
    <Image
      src={photoBacklit}
      alt=""
      class="absolute inset-0 -z-10 w-full h-full object-cover"
      loading="eager"
      widths={[640, 1024, 1600, 2400]}
      sizes="100vw"
    />
    <div
      class="absolute inset-0 -z-10"
      style="background: linear-gradient(180deg, rgba(15,38,24,0.35) 0%, rgba(15,38,24,0.10) 35%, rgba(15,38,24,0.85) 100%);"
    >
    </div>

    <div class="mx-auto max-w-6xl px-6 pt-28 pb-32 md:pt-40 md:pb-44">
      <p class="text-eyebrow text-gardn-sage">A garden assistant.</p>
      <h1
        class="text-display text-gardn-paper mt-4 max-w-4xl"
        style="text-wrap: balance;"
      >
        Notices what you'd miss.<br class="hidden md:inline" /> Remembers what you'd forget.
      </h1>
      <p class="text-h2 font-normal italic text-gardn-paper/85 mt-6 max-w-2xl">
        A garden app that grows with you — quietly keeping every border, plant and bloom in mind, and gently nudging you toward what's worth doing next.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-6">
        <a
          href="#waitlist"
          class="inline-flex items-center justify-center rounded-md bg-gardn-paper text-gardn-forest-deep text-button px-6 py-3 hover:bg-white transition-colors"
        >
          Join the waitlist
        </a>
        <a
          href="#memory"
          class="inline-flex items-center gap-2 text-label text-gardn-paper/85 hover:text-gardn-paper transition-colors"
        >
          See what it does
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6 9l6 6 6-6"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Block 2 — Memory section (dominant) -->
  <section id="memory" class="bg-gardn-paper">
    <div class="mx-auto max-w-6xl px-6 py-24 md:py-36">
      <div class="grid md:grid-cols-12 gap-12 md:gap-16 items-center">
        <div class="md:col-span-6">
          <Image
            src={photoCourtyard}
            alt="A settled, established garden — the look of time having passed."
            class="w-full h-[480px] md:h-[640px] object-cover rounded-lg"
            widths={[600, 1000, 1400]}
            sizes="(min-width: 768px) 50vw, 100vw"
          />
        </div>
        <div class="md:col-span-6">
          <p class="text-eyebrow text-gardn-fern">Your garden, remembered.</p>
          <h2
            class="text-h1 md:text-display text-gardn-forest-deep mt-4"
            style="text-wrap: balance; font-size: clamp(32px, 4vw, 48px); line-height: 1.05; letter-spacing: -1.2px;"
          >
            Every plant. Every border. Every season — kept.
          </h2>
          <div class="mt-8 space-y-5">
            <p class="text-body text-gardn-muted" style="font-size: 18px; line-height: 28px;">
              Most garden apps treat each visit as a transaction: identify a plant, set a watering reminder, move on. Gardn doesn't.
            </p>
            <p class="text-body text-gardn-muted" style="font-size: 18px; line-height: 28px;">
              Gardn keeps the record of your garden — every plant you've added, every photo you've taken, every issue you've spotted, every season you've been through. So when you scroll back through April, you can see your border in 2024 next to 2025 next to 2026. The shoot you almost missed. The rose that opened a fortnight earlier this year. The wisteria you've been quietly proud of for three summers running.
            </p>
            <p class="text-body text-gardn-muted" style="font-size: 18px; line-height: 28px;">
              The longer you use Gardn, the more it knows. The more it knows, the better the next nudge gets — because the advice that matters is the advice that's actually about <em>your</em> garden, not gardens in general.
            </p>
          </div>

          <blockquote class="mt-10 border-l-2 border-gardn-fern pl-6 italic text-gardn-forest-deep" style="font-size: 22px; line-height: 32px;">
            “You can't take a garden's memory with you. So we keep one for yours.”
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- Block 3 — Three smaller proof points -->
  <section class="bg-gardn-cream border-y border-gardn-line">
    <div class="mx-auto max-w-6xl px-6 py-20 md:py-24">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8">
        {
          proofPoints.map((p) => (
            <article class="flex flex-col">
              <Image
                src={p.photo}
                alt={p.photoAlt}
                class="w-full h-56 object-cover rounded-md"
                widths={[400, 800]}
                sizes="(min-width: 768px) 33vw, 100vw"
              />
              <p class="text-eyebrow text-gardn-fern mt-6">{p.eyebrow}</p>
              <h3 class="text-h2 text-gardn-forest-deep mt-2" style="font-size: 22px; line-height: 26px; letter-spacing: -0.5px; text-wrap: balance;">
                {p.title}
              </h3>
              <p class="text-body-sm text-gardn-muted mt-3" style="font-size: 15px; line-height: 23px;">
                {p.body}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Block 4 — CTA (waitlist, pre-launch) -->
  <section id="waitlist" class="bg-gardn-paper">
    <div class="mx-auto max-w-2xl px-6 py-24 md:py-32 text-center">
      <p class="text-eyebrow text-gardn-fern">Launching soon.</p>
      <h2 class="text-h1 text-gardn-forest-deep mt-4" style="text-wrap: balance;">
        Get the app the day it lands.
      </h2>
      <p class="text-body text-gardn-muted mt-5 max-w-lg mx-auto">
        One email when Gardn opens on the App Store and Google Play. No newsletter, no follow-ups. Just the message that says it's here.
      </p>

      <form id="waitlist-form" class="mt-10 flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <label for="waitlist-email" class="sr-only">Email</label>
        <input
          id="waitlist-email"
          name="email"
          type="email"
          required
          autocomplete="email"
          placeholder="your@email.com"
          class="flex-1 rounded-md border border-gardn-line bg-gardn-cream px-4 py-3 text-body text-gardn-forest-deep placeholder:text-gardn-muted-sub focus:outline-none focus:border-gardn-fern"
        />
        <button
          type="submit"
          class="rounded-md bg-gardn-fern text-gardn-paper text-button px-6 py-3 hover:bg-gardn-forest transition-colors"
        >
          Join waitlist
        </button>
      </form>
      <p id="waitlist-status" role="status" aria-live="polite" class="text-body-sm text-gardn-muted-sub mt-4 min-h-[1.25rem]"></p>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('waitlist-form') as HTMLFormElement | null;
  const status = document.getElementById('waitlist-status') as HTMLParagraphElement | null;
  if (form && status) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const email = String(data.get('email') ?? '').trim();
      if (!email) return;
      status.textContent = 'Adding you to the list…';
      try {
        const res = await fetch('/api/waitlist', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        const json = (await res.json()) as { ok: boolean; error?: string };
        if (json.ok) {
          status.textContent = "Thanks. We'll be in touch when the app's live.";
          form.reset();
        } else {
          status.textContent = json.error ?? 'That didn’t work. Try again?';
        }
      } catch {
        status.textContent = "No signal. We'll be here when you're back.";
      }
    });
  }
</script>
