---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { photoMeadow } from '../../constants/brandAssets';
---

<BaseLayout
  title="Notes — Gardn"
  description="A gardener's notebook. Short pieces about the things we've noticed building Gardn — what works, what doesn't, what we've learned about real gardens from real gardeners."
>
  <article class="mx-auto max-w-2xl px-6 pt-16 pb-24 md:pt-24 md:pb-32">
    <Image
      src={photoMeadow}
      alt="A meadow in soft light."
      class="w-full h-72 md:h-96 object-cover rounded-lg"
      widths={[480, 800, 1200]}
      sizes="(min-width: 768px) 672px, 100vw"
    />
    <p class="text-eyebrow text-gardn-fern mt-12">A gardener's notebook.</p>
    <h1 class="text-h1 text-gardn-forest-deep mt-3" style="text-wrap: balance;">
      Notes from the garden.
    </h1>

    <div class="mt-8 space-y-5">
      <p class="text-body text-gardn-muted">
        Short pieces about the things we've noticed building Gardn — what works, what doesn't, what we've learned about real gardens from real gardeners. Unpolished where it should be unpolished. Specific where we can be specific.
      </p>
      <p class="text-body text-gardn-muted">
        No marketing newsletter. No sequence. Just notes, when there's something worth writing down.
      </p>
    </div>
  </article>
</BaseLayout>
