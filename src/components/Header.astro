---
import { Image } from 'astro:assets';
import { gardnLockupHorizontal } from '../constants/brandAssets';

const links = [
  { href: '/', label: 'Home' },
  { href: '/support', label: 'Support' },
  { href: '/blog', label: 'Notes' },
];
---

<header
  class="sticky top-0 z-40 bg-gardn-paper/90 backdrop-blur border-b border-gardn-line"
>
  <div class="mx-auto max-w-6xl px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center text-gardn-forest-deep" aria-label="Gardn — home">
      <Image
        src={gardnLockupHorizontal}
        alt="Gardn"
        widths={[260, 520]}
        sizes="(min-width: 768px) 240px, 215px"
        class="h-9 md:h-[52px] w-auto"
        loading="eager"
      />
    </a>
    <nav class="flex items-center gap-6">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="text-label text-gardn-muted hover:text-gardn-forest-deep transition-colors"
          >
            {l.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
