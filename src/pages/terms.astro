---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Terms — Gardn"
  description="Gardn's Terms of Service are being finalised by counsel and will be live here before App Store submission."
>
  <section class="mx-auto max-w-2xl px-6 pt-24 pb-32 md:pt-32 md:pb-40 text-center">
    <p class="text-eyebrow text-gardn-fern">Terms</p>
    <h1 class="text-h1 text-gardn-forest-deep mt-4" style="text-wrap: balance;">
      Terms of Service.
    </h1>
    <p class="text-body text-gardn-muted mt-8 max-w-xl mx-auto">
      Our Terms of Service are being finalised by counsel and will be live here before App Store submission.
    </p>
    <p class="text-body text-gardn-muted mt-4 max-w-xl mx-auto">
      For early access, email <a href="mailto:privacy@gardn.world" class="underline decoration-gardn-fern decoration-2 underline-offset-4">privacy@gardn.world</a>.
    </p>
  </section>
</BaseLayout>
