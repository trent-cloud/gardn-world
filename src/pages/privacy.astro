---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy — Gardn">
  <section class="mx-auto max-w-3xl px-6 py-20">
    <p class="text-eyebrow text-gardn-fern mb-4">Privacy</p>
    <h1 class="text-h1 text-gardn-forest-deep">Privacy Policy</h1>
    <p class="text-body text-gardn-muted mt-6">
      Content reviewed by external solicitor, full text landing here imminently. Contact
      <a href="mailto:privacy@gardn.world" class="underline">privacy@gardn.world</a> for early
      access.
    </p>
  </section>
</BaseLayout>
